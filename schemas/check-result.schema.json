{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["check_id", "title", "category", "status"],
  "properties": {
    "check_id": { "type": "string", "pattern": "^[a-z]+-[a-z-]+$" },
    "title": { "type": "string", "maxLength": 200 },
    "category": { "type": "string", "enum": ["secrets", "mcp", "plugins", "hooks", "trust", "config"] },
    "status": { "type": "string", "enum": ["PASS", "WARN", "FAIL", "SKIP", "UNSUPPORTED"] },
    "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "detail"],
        "properties": {
          "type": { "type": "string", "enum": ["file", "config", "runtime", "process"] },
          "path": { "type": "string" },
          "detail": { "type": "string", "maxLength": 500 },
          "snippet": { "type": "string", "maxLength": 256 },
          "redacted": { "type": "boolean" }
        }
      }
    },
    "remediation": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "argv": { "type": "array", "items": { "type": "string" } },
        "risk": { "type": "string", "enum": ["safe", "caution", "dangerous"] }
      }
    }
  },
  "additionalProperties": false
}
